#include "Cygnus.dtsi"
#include <input/processors.dtsi>
#include <behaviors/input_gestures_accel.dtsi>
#include <dt-bindings/input/input-event-codes.h>

&default_transform {
    col-offset = <7>;
};

&kscan0 {
        col-gpios
            = <&xiao_d 10 GPIO_ACTIVE_HIGH>
            , <&xiao_d 9 GPIO_ACTIVE_HIGH>
            , <&xiao_d 8 GPIO_ACTIVE_HIGH>
            , <&xiao_d 7 GPIO_ACTIVE_HIGH>
            , <&gpio0 10 GPIO_ACTIVE_HIGH>
            , <&gpio1 10 GPIO_ACTIVE_HIGH>
            ;
};

/ {
    zip_temp_layer_threshold: zip_temp_layer_threshold {
        compatible = "zmk,input-processor-temp-layer-threshold";
        #input-processor-cells = <2>;
        threshold = <600>;         /* 約1/5回転 (25mm球, 1000CPI) */
        reset-timeout-ms = <200>;  /* 動きが止まったらカウントリセット */
    };

    scroll_inertia: scroll_inertia {
        compatible = "zmk,input-processor-scroll-inertia";
        #input-processor-cells = <0>;

        /* EMAフィルタ (gain+blend=1000) */
        gain     = <300>;         /* α≈0.3: 新入力の反映度 */
        blend    = <700>;         /* 直前速度の維持度 */

        /* 慣性開始条件 */
        start    = <3>;           /* 速度閾値 (scroll_scaler後の単位) */
        move     = <15>;          /* 累積移動量閾値 */
        release  = <24>;          /* 離し判定 (ms, 125Hz×3フレーム) */

        /* 2段階減衰 */
        fast     = <5>;           /* 高速/低速の境界 */
        decay-fast = <960>;       /* 高速域: なめらかに伸びる */
        decay-slow = <870>;       /* 低速域: ピタッと止まる */
        stop     = <1>;           /* これ以下で即停止 */

        /* 出力制御 */
        scale    = <1000>;        /* 1:1マッピング */
        limit    = <15>;          /* scroll_scaler後の上限 */
        span     = <600>;         /* 最大持続 (ms) */
        tick     = <8>;           /* 更新周期 (ms, 125Hzに合わせる) */

        /* 動作 */
        axis     = <0>;           /* 0=両軸 */
        cancel   = <0>;           /* 0=即キャンセル */
        layer    = <4>;           /* SCROLLレイヤー */
    };

    trackball_listener: trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball>;
        input-processors = <
            &pointer_accel
            &zip_y_scaler 21 20
            &zip_temp_layer_threshold 3 10000
        >;

        scroller {
            layers = <4>;
            input-processors = <
                &pointer_accel
                &zip_y_scaler (-1) 1
                &zip_xy_to_scroll_mapper
                &zip_scroll_scaler 4 450
                &scroll_inertia
            >;
        };
    };
};

&pointer_accel {
    input-type = <INPUT_EV_REL>;
    min-factor = <80>;             /* 開始速度: 低速をさらに抑える */
    max-factor = <500>;            /* 最大速度: 加速の勢いを緩める */
    speed-threshold = <333>;       /* 加速開始点 */
    speed-max = <3000>;            /* この速度で最大に到達 */
    acceleration-exponent = <1>;   /* 線形 */
};

&xiao_serial { status = "disabled"; };

&pinctrl {
    spi0_default: spi0_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
        };
    };

    spi0_sleep: spi0_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
            low-power-enable;
        };
    };
};

&spi0 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;

    trackball: trackball@0 {
        status = "okay";
        compatible = "pixart,pmw3610";
        reg = <0>;
        spi-max-frequency = <2000000>;
        irq-gpios = <&gpio0 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
    };
};